{% extends 'admin.html.twig' %}

{% block admin %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Ajouter un invité</h1>
        <a href="{{ path('admin_guests_index') }}" class="btn btn-primary">Retour</a>
    </div>
    <p class="text-muted">Un mot de passe provisoire sera généré automatiquement et affiché après la création.</p>
    {{ form_start(form) }}
        {{ form_errors(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.email) }}
        {{ form_row(form.description) }}
        <button type="submit" class="btn btn-primary">Créer l’invité</button>
    {{ form_end(form) }}
{% endblock %}
